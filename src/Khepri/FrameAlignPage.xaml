<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Khepri.Presentation.Timelapse"
             x:Class="Khepri.FrameAlignPage"
             x:DataType="vm:FrameAlignViewModel"
             Shell.NavBarIsVisible="False"
             BackgroundColor="{AppThemeBinding Light=White, Dark=#111111}">

    <Grid RowDefinitions="Auto,*,Auto,Auto" Padding="0">

        <!-- ── Header ────────────────────────────────────────────────────── -->
        <Grid Grid.Row="0"
              ColumnDefinitions="Auto,*,Auto"
              Padding="20,52,20,12">

            <Button Grid.Column="0"
                    Text="← BACK"
                    FontSize="11"
                    CharacterSpacing="1"
                    Clicked="OnBackClicked"
                    BackgroundColor="Transparent"
                    TextColor="{AppThemeBinding Light=#888888, Dark=#666666}"
                    Padding="0,0,12,0" />

            <Label Grid.Column="1"
                   Text="{Binding ProgressText}"
                   FontSize="11"
                   FontAttributes="Bold"
                   CharacterSpacing="3"
                   VerticalOptions="Center"
                   TextColor="{AppThemeBinding Light=Black, Dark=White}" />

            <ActivityIndicator Grid.Column="1"
                               IsRunning="{Binding IsBusy}"
                               IsVisible="{Binding IsBusy}"
                               HorizontalOptions="End"
                               VerticalOptions="Center"
                               Color="{AppThemeBinding Light=Black, Dark=White}"
                               WidthRequest="16"
                               HeightRequest="16"
                               Margin="0,0,4,0" />

            <StackLayout Grid.Column="2"
                         Orientation="Horizontal"
                         Spacing="0">
                <Button Text="RESET"
                        FontSize="11"
                        CharacterSpacing="1"
                        Command="{Binding ResetCommand}"
                        BackgroundColor="Transparent"
                        TextColor="{AppThemeBinding Light=#888888, Dark=#666666}"
                        Padding="8,0" />
                <Button Text="RESET ALL"
                        FontSize="11"
                        CharacterSpacing="1"
                        Command="{Binding ResetAllCommand}"
                        BackgroundColor="Transparent"
                        TextColor="{AppThemeBinding Light=#888888, Dark=#666666}"
                        Padding="8,0" />
            </StackLayout>

        </Grid>

        <!-- ── Ghost viewer ──────────────────────────────────────────────── -->
        <Grid Grid.Row="1"
              BackgroundColor="{AppThemeBinding Light=#EEEEEE, Dark=#1A1A1A}"
              IsClippedToBounds="True"
              x:Name="ViewerGrid">

            <!-- Bottom: frame being repositioned — opaque, draggable -->
            <Image x:Name="CurrentImage"
                   Source="{Binding BackgroundPath}"
                   Aspect="AspectFit"
                   TranslationX="{Binding OffsetX}"
                   TranslationY="{Binding OffsetY}"
                   Rotation="{Binding Rotation}"
                   Scale="{Binding Scale}" />

            <!-- Top: already-aligned reference ghost — rendered at its saved playback offset, fixed -->
            <Image x:Name="GhostImage"
                   Source="{Binding GhostPath}"
                   Aspect="AspectFit"
                   Opacity="{Binding GhostOpacity}"
                   TranslationX="{Binding GhostOffsetX}"
                   TranslationY="{Binding GhostOffsetY}"
                   Rotation="{Binding GhostRotation}"
                   Scale="{Binding GhostScale}"
                   InputTransparent="True" />

            <!-- Center crosshair (reference point) -->
            <BoxView WidthRequest="1"
                     HeightRequest="40"
                     BackgroundColor="#40FFFFFF"
                     HorizontalOptions="Center"
                     VerticalOptions="Center"
                     InputTransparent="True" />
            <BoxView WidthRequest="40"
                     HeightRequest="1"
                     BackgroundColor="#40FFFFFF"
                     HorizontalOptions="Center"
                     VerticalOptions="Center"
                     InputTransparent="True" />

            <!-- "✓ SAVED" flash indicator -->
            <Label x:Name="SavedLabel"
                   Text="✓ SAVED"
                   FontSize="11"
                   FontAttributes="Bold"
                   CharacterSpacing="2"
                   TextColor="White"
                   BackgroundColor="#99000000"
                   Padding="12,6"
                   HorizontalOptions="Center"
                   VerticalOptions="End"
                   Margin="0,0,0,12"
                   IsVisible="False"
                   InputTransparent="True" />

        </Grid>

        <!-- ── Controls bar ──────────────────────────────────────────────── -->
        <Grid Grid.Row="2"
              BackgroundColor="{AppThemeBinding Light=#F5F5F5, Dark=#1A1A1A}"
              RowDefinitions="Auto,Auto,Auto">

            <!-- Filmstrip -->
            <CollectionView x:Name="FilmstripView"
                            Grid.Row="0"
                            ItemsSource="{Binding FilmstripItems}"
                            HeightRequest="72"
                            BackgroundColor="{AppThemeBinding Light=#F5F5F5, Dark=#1A1A1A}"
                            SelectionMode="None">
                <CollectionView.ItemsLayout>
                    <LinearItemsLayout Orientation="Horizontal" ItemSpacing="4" />
                </CollectionView.ItemsLayout>
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="vm:FilmstripItem">
                        <Border WidthRequest="56"
                                HeightRequest="56"
                                Margin="0,8"
                                Padding="0"
                                Stroke="{AppThemeBinding Light=Black, Dark=White}"
                                StrokeThickness="{Binding ActiveStrokeThickness}">
                            <Image Source="{Binding FilePath}"
                                   Aspect="AspectFill"
                                   WidthRequest="56"
                                   HeightRequest="56" />
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <!-- Ghost opacity slider -->
            <Grid Grid.Row="1"
                  ColumnDefinitions="Auto,*,Auto"
                  Padding="20,8,20,4">
                <Label Grid.Column="0"
                       Text="GHOST"
                       FontSize="9"
                       FontAttributes="Bold"
                       CharacterSpacing="2"
                       VerticalOptions="Center"
                       TextColor="{AppThemeBinding Light=#888888, Dark=#666666}"
                       Margin="0,0,12,0" />
                <Slider Grid.Column="1"
                        Minimum="0.1" Maximum="0.9"
                        Value="{Binding GhostOpacity}"
                        ThumbColor="{AppThemeBinding Light=Black, Dark=White}"
                        MinimumTrackColor="{AppThemeBinding Light=Black, Dark=White}"
                        MaximumTrackColor="{AppThemeBinding Light=#DDDDDD, Dark=#333333}" />
                <Label Grid.Column="2"
                       Text="{Binding GhostOpacity, StringFormat='{0:P0}'}"
                       FontSize="11"
                       FontAttributes="Bold"
                       VerticalOptions="Center"
                       TextColor="{AppThemeBinding Light=Black, Dark=White}"
                       MinimumWidthRequest="40"
                       HorizontalTextAlignment="End" />
            </Grid>

            <!-- PREV / NEXT / PRECISION -->
            <Grid Grid.Row="2"
                  ColumnDefinitions="Auto,Auto,*"
                  ColumnSpacing="8"
                  Padding="20,4,20,40">

                <Button Grid.Column="0"
                        Text="◀ PREV"
                        FontSize="10"
                        CharacterSpacing="1"
                        Command="{Binding PrevCommand}"
                        IsEnabled="{Binding CanGoPrev}"
                        BackgroundColor="{AppThemeBinding Light=#EEEEEE, Dark=#222222}"
                        TextColor="{AppThemeBinding Light=Black, Dark=White}"
                        CornerRadius="0"
                        Padding="14,8" />

                <Button Grid.Column="1"
                        Text="NEXT ▶"
                        FontSize="10"
                        CharacterSpacing="1"
                        Command="{Binding NextCommand}"
                        IsEnabled="{Binding CanGoNext}"
                        BackgroundColor="{AppThemeBinding Light=#EEEEEE, Dark=#222222}"
                        TextColor="{AppThemeBinding Light=Black, Dark=White}"
                        CornerRadius="0"
                        Padding="14,8" />

                <Button Grid.Column="2"
                        x:Name="PrecisionToggleButton"
                        Text="▼ PRECISION"
                        FontSize="10"
                        CharacterSpacing="1"
                        Clicked="OnPrecisionToggleClicked"
                        BackgroundColor="Transparent"
                        TextColor="{AppThemeBinding Light=#888888, Dark=#666666}"
                        HorizontalOptions="End"
                        Padding="8,4" />

            </Grid>

        </Grid>

        <!-- ── Precision panel ───────────────────────────────────────────── -->
        <ScrollView Grid.Row="3"
                    x:Name="PrecisionPanel"
                    IsVisible="False">
            <Grid RowDefinitions="48,48,48,48"
                  RowSpacing="0"
                  Padding="20,8,20,40">

                <!-- Offset X -->
                <Grid Grid.Row="0"
                      ColumnDefinitions="72,36,*,36"
                      ColumnSpacing="8"
                      VerticalOptions="Center">
                    <Label Grid.Column="0" Text="OFFSET X"
                           FontSize="9" FontAttributes="Bold" CharacterSpacing="1"
                           VerticalOptions="Center"
                           TextColor="{AppThemeBinding Light=#888888, Dark=#666666}" />
                    <Button Grid.Column="1" Text="−" FontSize="20" Padding="0"
                            WidthRequest="36" HeightRequest="36" CornerRadius="4"
                            BackgroundColor="{AppThemeBinding Light=#F0F0F0, Dark=#222222}"
                            TextColor="{AppThemeBinding Light=Black, Dark=White}"
                            Clicked="OnOffsetXDec" VerticalOptions="Center" />
                    <Entry Grid.Column="2" x:Name="OffsetXEntry"
                           Keyboard="Numeric" FontSize="13" FontAttributes="Bold"
                           HorizontalTextAlignment="Center" BackgroundColor="Transparent"
                           TextColor="{AppThemeBinding Light=Black, Dark=White}"
                           ReturnType="Done" VerticalOptions="Center"
                           Completed="OnOffsetXCompleted"
                           Unfocused="OnOffsetXUnfocused" />
                    <Button Grid.Column="3" Text="+" FontSize="20" Padding="0"
                            WidthRequest="36" HeightRequest="36" CornerRadius="4"
                            BackgroundColor="{AppThemeBinding Light=#F0F0F0, Dark=#222222}"
                            TextColor="{AppThemeBinding Light=Black, Dark=White}"
                            Clicked="OnOffsetXInc" VerticalOptions="Center" />
                </Grid>

                <!-- Offset Y -->
                <Grid Grid.Row="1"
                      ColumnDefinitions="72,36,*,36"
                      ColumnSpacing="8"
                      VerticalOptions="Center">
                    <Label Grid.Column="0" Text="OFFSET Y"
                           FontSize="9" FontAttributes="Bold" CharacterSpacing="1"
                           VerticalOptions="Center"
                           TextColor="{AppThemeBinding Light=#888888, Dark=#666666}" />
                    <Button Grid.Column="1" Text="−" FontSize="20" Padding="0"
                            WidthRequest="36" HeightRequest="36" CornerRadius="4"
                            BackgroundColor="{AppThemeBinding Light=#F0F0F0, Dark=#222222}"
                            TextColor="{AppThemeBinding Light=Black, Dark=White}"
                            Clicked="OnOffsetYDec" VerticalOptions="Center" />
                    <Entry Grid.Column="2" x:Name="OffsetYEntry"
                           Keyboard="Numeric" FontSize="13" FontAttributes="Bold"
                           HorizontalTextAlignment="Center" BackgroundColor="Transparent"
                           TextColor="{AppThemeBinding Light=Black, Dark=White}"
                           ReturnType="Done" VerticalOptions="Center"
                           Completed="OnOffsetYCompleted"
                           Unfocused="OnOffsetYUnfocused" />
                    <Button Grid.Column="3" Text="+" FontSize="20" Padding="0"
                            WidthRequest="36" HeightRequest="36" CornerRadius="4"
                            BackgroundColor="{AppThemeBinding Light=#F0F0F0, Dark=#222222}"
                            TextColor="{AppThemeBinding Light=Black, Dark=White}"
                            Clicked="OnOffsetYInc" VerticalOptions="Center" />
                </Grid>

                <!-- Rotation -->
                <Grid Grid.Row="2"
                      ColumnDefinitions="72,36,*,36"
                      ColumnSpacing="8"
                      VerticalOptions="Center">
                    <Label Grid.Column="0" Text="ROTATION"
                           FontSize="9" FontAttributes="Bold" CharacterSpacing="1"
                           VerticalOptions="Center"
                           TextColor="{AppThemeBinding Light=#888888, Dark=#666666}" />
                    <Button Grid.Column="1" Text="−" FontSize="20" Padding="0"
                            WidthRequest="36" HeightRequest="36" CornerRadius="4"
                            BackgroundColor="{AppThemeBinding Light=#F0F0F0, Dark=#222222}"
                            TextColor="{AppThemeBinding Light=Black, Dark=White}"
                            Clicked="OnRotationDec" VerticalOptions="Center" />
                    <Entry Grid.Column="2" x:Name="RotationEntry"
                           Keyboard="Numeric" FontSize="13" FontAttributes="Bold"
                           HorizontalTextAlignment="Center" BackgroundColor="Transparent"
                           TextColor="{AppThemeBinding Light=Black, Dark=White}"
                           ReturnType="Done" VerticalOptions="Center"
                           Completed="OnRotationCompleted"
                           Unfocused="OnRotationUnfocused" />
                    <Button Grid.Column="3" Text="+" FontSize="20" Padding="0"
                            WidthRequest="36" HeightRequest="36" CornerRadius="4"
                            BackgroundColor="{AppThemeBinding Light=#F0F0F0, Dark=#222222}"
                            TextColor="{AppThemeBinding Light=Black, Dark=White}"
                            Clicked="OnRotationInc" VerticalOptions="Center" />
                </Grid>

                <!-- Zoom -->
                <Grid Grid.Row="3"
                      ColumnDefinitions="72,36,*,36"
                      ColumnSpacing="8"
                      VerticalOptions="Center">
                    <Label Grid.Column="0" Text="ZOOM"
                           FontSize="9" FontAttributes="Bold" CharacterSpacing="1"
                           VerticalOptions="Center"
                           TextColor="{AppThemeBinding Light=#888888, Dark=#666666}" />
                    <Button Grid.Column="1" Text="−" FontSize="20" Padding="0"
                            WidthRequest="36" HeightRequest="36" CornerRadius="4"
                            BackgroundColor="{AppThemeBinding Light=#F0F0F0, Dark=#222222}"
                            TextColor="{AppThemeBinding Light=Black, Dark=White}"
                            Clicked="OnScaleDec" VerticalOptions="Center" />
                    <Entry Grid.Column="2" x:Name="ScaleEntry"
                           Keyboard="Numeric" FontSize="13" FontAttributes="Bold"
                           HorizontalTextAlignment="Center" BackgroundColor="Transparent"
                           TextColor="{AppThemeBinding Light=Black, Dark=White}"
                           ReturnType="Done" VerticalOptions="Center"
                           Completed="OnScaleCompleted"
                           Unfocused="OnScaleUnfocused" />
                    <Button Grid.Column="3" Text="+" FontSize="20" Padding="0"
                            WidthRequest="36" HeightRequest="36" CornerRadius="4"
                            BackgroundColor="{AppThemeBinding Light=#F0F0F0, Dark=#222222}"
                            TextColor="{AppThemeBinding Light=Black, Dark=White}"
                            Clicked="OnScaleInc" VerticalOptions="Center" />
                </Grid>

            </Grid>
        </ScrollView>

    </Grid>
</ContentPage>
