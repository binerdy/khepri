<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:Khepri"
             xmlns:vm="clr-namespace:Khepri.Presentation.Timelapse"
             x:Class="Khepri.ProjectDetailPage"
             x:DataType="vm:ProjectDetailViewModel"
             Shell.NavBarIsVisible="False"
             BackgroundColor="{AppThemeBinding Light=White, Dark=#111111}">

    <Grid RowDefinitions="Auto,*,Auto" Padding="0">

        <!-- ── Header ─────────────────────────────────────────────────────── -->
        <Grid Grid.Row="0" Padding="20,52,20,12">

            <!-- Single header — bin disabled until selection mode -->
            <Grid ColumnDefinitions="Auto,*,Auto,Auto,Auto,Auto,Auto,Auto,Auto">

                <!-- Back / Cancel -->
                <Button Grid.Column="0"
                        Text="← BACK"
                        FontSize="11"
                        CharacterSpacing="1"
                        Clicked="OnBackClicked"
                        BackgroundColor="Transparent"
                        TextColor="{AppThemeBinding Light=#888888, Dark=#666666}"
                        IsVisible="{Binding IsNotSelecting}"
                        Padding="0,0,12,0" />

                <Button Grid.Column="0"
                        Text="CANCEL"
                        FontSize="11"
                        CharacterSpacing="1"
                        Clicked="OnExitSelectModeClicked"
                        BackgroundColor="Transparent"
                        TextColor="{AppThemeBinding Light=#888888, Dark=#666666}"
                        IsVisible="{Binding IsSelecting}"
                        Padding="0,0,4,0" />

                <!-- Project name / selected count -->
                <Label Grid.Column="1"
                       Text="{Binding Project.Name}"
                       FontSize="11"
                       FontAttributes="Bold"
                       CharacterSpacing="3"
                       VerticalOptions="Center"
                       HorizontalOptions="Fill"
                       LineBreakMode="TailTruncation"
                       IsVisible="{Binding IsNotSelecting}"
                       TextColor="{AppThemeBinding Light=Black, Dark=White}" />

                <Label Grid.Column="1"
                       Text="{Binding SelectedCount, StringFormat='{0} SELECTED'}"
                       FontSize="11"
                       FontAttributes="Bold"
                       CharacterSpacing="2"
                       VerticalOptions="Center"
                       IsVisible="{Binding IsSelecting}"
                       TextColor="{AppThemeBinding Light=Black, Dark=White}" />

                <ActivityIndicator Grid.Column="1"
                                   IsRunning="{Binding IsBusy}"
                                   IsVisible="{Binding IsBusy}"
                                   HorizontalOptions="End"
                                   VerticalOptions="Center"
                                   Color="{AppThemeBinding Light=Black, Dark=White}"
                                   WidthRequest="16"
                                   HeightRequest="16"
                                   Margin="0,0,4,0" />

                <!-- Edit -->
                <ImageButton Grid.Column="2"
                             WidthRequest="44"
                             HeightRequest="44"
                             Padding="12"
                             BackgroundColor="Transparent"
                             IsVisible="{Binding IsNotSelecting}"
                             Source="{AppThemeBinding Light=edit_dark.svg, Dark=edit_light.svg}"
                             Clicked="OnEditClicked" />

                <!-- Play -->
                <ImageButton Grid.Column="3"
                             WidthRequest="44"
                             HeightRequest="44"
                             Padding="11"
                             BackgroundColor="Transparent"
                             IsEnabled="{Binding HasFrames}"
                             IsVisible="{Binding IsNotSelecting}"
                             Source="{AppThemeBinding Light=play_dark.svg, Dark=play_light.svg}"
                             Clicked="OnPlayClicked" />

                <!-- Align -->
                <Button Grid.Column="4"
                        Text="ALIGN"
                        FontSize="11"
                        CharacterSpacing="1"
                        Clicked="OnAlignClicked"
                        BackgroundColor="Transparent"
                        TextColor="{AppThemeBinding Light=#888888, Dark=#666666}"
                        IsEnabled="{Binding HasFrames}"
                        IsVisible="{Binding IsNotSelecting}"
                        Padding="8,0" />

                <!-- Share frames -->
                <Button Grid.Column="5"
                        Text="SHARE"
                        FontSize="11"
                        CharacterSpacing="1"
                        Padding="12"
                        BackgroundColor="Transparent"
                        TextColor="{AppThemeBinding Light=#888888, Dark=#666666}"
                        IsEnabled="{Binding HasFrames}"
                        IsVisible="{Binding IsNotSelecting}"
                        Clicked="OnShareFramesClicked" />

                <!-- Import from gallery -->
                <Button Grid.Column="6"
                        Text="IMPORT"
                        FontSize="11"
                        CharacterSpacing="1"
                        Padding="12"
                        BackgroundColor="Transparent"
                        TextColor="{AppThemeBinding Light=#888888, Dark=#666666}"
                        IsVisible="{Binding IsNotSelecting}"
                        Clicked="OnImportFromGalleryClicked" />

                <!-- Bin - hidden in selection mode -->
                <ImageButton Grid.Column="7"
                             WidthRequest="44"
                             HeightRequest="44"
                             Padding="12"
                             BackgroundColor="Transparent"
                             IsVisible="{Binding IsNotSelecting}"
                             Source="{AppThemeBinding Light=bin_dark.svg, Dark=bin_light.svg}"
                             Clicked="OnDeleteSelectedClicked" />

                <!-- OK — visible in selection mode to confirm delete/share -->
                <Button Grid.Column="8"
                        Text="OK"
                        FontSize="11"
                        FontAttributes="Bold"
                        CharacterSpacing="1"
                        Clicked="OnConfirmClicked"
                        BackgroundColor="Transparent"
                        TextColor="{AppThemeBinding Light=Black, Dark=White}"
                        IsVisible="{Binding IsSelecting}"
                        Padding="8,0"
                        MinimumWidthRequest="40" />

            </Grid>

        </Grid>

        <!-- ── Frame gallery ──────────────────────────────────────────────── -->
        <CollectionView Grid.Row="1"
                        ItemsSource="{Binding DisplayFrames}"
                        Margin="20,0,20,0">
            <CollectionView.ItemsLayout>
                <GridItemsLayout Orientation="Vertical"
                                 Span="2"
                                 VerticalItemSpacing="20"
                                 HorizontalItemSpacing="12" />
            </CollectionView.ItemsLayout>

            <CollectionView.EmptyView>
                <VerticalStackLayout HorizontalOptions="Center"
                                     VerticalOptions="Center"
                                     Spacing="6"
                                     Margin="32,48">
                    <Label Text="NO FRAMES"
                           FontSize="11"
                           FontAttributes="Bold"
                           CharacterSpacing="3"
                           HorizontalOptions="Center"
                           TextColor="{AppThemeBinding Light=#BBBBBB, Dark=#444444}" />
                    <Label Text="Tap CAPTURE to take the first photo."
                           FontSize="12"
                           HorizontalOptions="Center"
                           TextColor="{AppThemeBinding Light=#BBBBBB, Dark=#444444}" />
                </VerticalStackLayout>
            </CollectionView.EmptyView>

            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="vm:FrameDisplayItem">
                    <Grid RowDefinitions="Auto,Auto,Auto"
                          Padding="0,0,0,4">

                        <Grid.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnFrameTapped" />
                            <DragGestureRecognizer CanDrag="True" DragStarting="OnFrameDragStarting" />
                            <DropGestureRecognizer AllowDrop="True" Drop="OnFrameDrop" />
                        </Grid.GestureRecognizers>

                        <!-- Thumbnail placeholder -->
                        <BoxView Grid.Row="0"
                                 HeightRequest="160"
                                 BackgroundColor="{AppThemeBinding Light=#F2F2F2, Dark=#1E1E1E}" />

                        <!-- Photo -->
                        <Image Grid.Row="0"
                               Source="{Binding FrameFilePath}"
                               Aspect="AspectFill"
                               HeightRequest="160" />

                        <!-- "FRAME N" label — bottom-left of thumbnail -->
                        <Label Grid.Row="0"
                               Text="{Binding Label}"
                               FontSize="8"
                               FontAttributes="Bold"
                               CharacterSpacing="1"
                               TextColor="White"
                               BackgroundColor="#66000000"
                               HorizontalOptions="Start"
                               VerticalOptions="End"
                               Padding="4,2" />

                        <!-- Selection overlay -->
                        <BoxView Grid.Row="0"
                                 BackgroundColor="#99000000"
                                 IsVisible="{Binding IsSelected}" />

                        <!-- Checkmark -->
                        <Label Grid.Row="0"
                               Text="✓"
                               FontSize="16"
                               FontAttributes="Bold"
                               TextColor="White"
                               HorizontalOptions="End"
                               VerticalOptions="Start"
                               Margin="0,10,10,0"
                               IsVisible="{Binding IsSelected}" />

                        <!-- Separator -->
                        <BoxView Grid.Row="1"
                                 HeightRequest="1"
                                 BackgroundColor="{AppThemeBinding Light=Black, Dark=White}" />

                        <!-- Date -->
                        <Label Grid.Row="2"
                               Text="{Binding FrameDisplayDate}"
                               FontSize="10"
                               CharacterSpacing="0.5"
                               TextColor="{AppThemeBinding Light=#888888, Dark=#666666}"
                               Margin="0,4,0,0" />
                    </Grid>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <!-- ── Footer actions ─────────────────────────────────────────────── -->
        <Grid Grid.Row="2"
              ColumnDefinitions="*,*,*"
              ColumnSpacing="12"
              Padding="20,16,20,36"
              IsVisible="{Binding IsNotSelecting}">

            <Button Grid.Column="0"
                    Text="CAPTURE"
                    FontSize="11"
                    FontAttributes="Bold"
                    CharacterSpacing="2"
                    Command="{Binding CaptureCommand}"
                    BackgroundColor="{AppThemeBinding Light=Black, Dark=White}"
                    TextColor="{AppThemeBinding Light=White, Dark=#111111}"
                    CornerRadius="0" />

            <Button Grid.Column="2"
                    Text="RETAKE LAST"
                    FontSize="11"
                    CharacterSpacing="1"
                    Command="{Binding RetakeCommand}"
                    IsEnabled="{Binding HasFrames}"
                    BackgroundColor="Transparent"
                    TextColor="{AppThemeBinding Light=Black, Dark=White}"
                    BorderColor="{AppThemeBinding Light=Black, Dark=White}"
                    BorderWidth="1"
                    CornerRadius="0" />
        </Grid>

    </Grid>

</ContentPage>

