<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Khepri.TimelapsePreviewPage"
             Shell.NavBarIsVisible="False"
             BackgroundColor="{AppThemeBinding Light=White, Dark=#111111}">

    <Grid RowDefinitions="Auto,*,Auto,Auto">

        <!-- ── Header ─────────────────────────────────────────────────────── -->
        <Grid Grid.Row="0"
              ColumnDefinitions="Auto,*"
              Padding="20,52,20,12">

            <Button Grid.Column="0"
                    Text="← BACK"
                    FontSize="11"
                    CharacterSpacing="1"
                    Clicked="OnBackClicked"
                    BackgroundColor="Transparent"
                    TextColor="{AppThemeBinding Light=#888888, Dark=#666666}"
                    Padding="0,0,12,0" />

            <Label Grid.Column="1"
                   Text="{Binding ProjectName}"
                   FontSize="11"
                   FontAttributes="Bold"
                   CharacterSpacing="3"
                   VerticalOptions="Center"
                   LineBreakMode="TailTruncation"
                   TextColor="{AppThemeBinding Light=Black, Dark=White}" />
        </Grid>

        <!-- ── Preview frame ──────────────────────────────────────────────── -->
        <Grid Grid.Row="1"
              BackgroundColor="Black">
            <!-- New frame (data-bound, underneath) -->
            <Image x:Name="FrameImage"
                   Source="{Binding CurrentFramePath}"
                   Aspect="AspectFit"
                   HorizontalOptions="Fill"
                   VerticalOptions="Fill"
                   TranslationX="{Binding CurrentOffsetX}"
                   TranslationY="{Binding CurrentOffsetY}"
                   Rotation="{Binding CurrentRotation}"
                   Scale="{Binding CurrentScale}" />

            <!-- Dissolve overlay — old frame fades out over the new one; not data-bound -->
            <Image x:Name="FrameImageOverlay"
                   Aspect="AspectFit"
                   HorizontalOptions="Fill"
                   VerticalOptions="Fill"
                   IsVisible="False"
                   InputTransparent="True" />

            <Label Text="{Binding ProgressText}"
                   FontSize="10"
                   FontAttributes="Bold"
                   CharacterSpacing="1"
                   TextColor="White"
                   BackgroundColor="#66000000"
                   HorizontalOptions="End"
                   VerticalOptions="End"
                   Padding="8,4"
                   Margin="0,0,0,0" />

            <Grid.GestureRecognizers>
                <TapGestureRecognizer Tapped="OnFrameTapped" />
            </Grid.GestureRecognizers>
        </Grid>

        <!-- ── Playback bar ───────────────────────────────────────────────── -->
        <Grid Grid.Row="2"
              ColumnDefinitions="Auto,Auto,*,Auto"
              Padding="20,12,20,4"
              ColumnSpacing="12">

            <Button Grid.Column="0"
                    Text="■ STOP"
                    FontSize="10"
                    CharacterSpacing="1"
                    Clicked="OnStopClicked"
                    BackgroundColor="Transparent"
                    TextColor="{AppThemeBinding Light=Black, Dark=White}"
                    Padding="8,4"
                    MinimumWidthRequest="60" />

            <Button Grid.Column="1"
                    Text="{Binding PlayPauseText}"
                    FontSize="10"
                    CharacterSpacing="1"
                    Clicked="OnTogglePlayClicked"
                    BackgroundColor="{AppThemeBinding Light=Black, Dark=White}"
                    TextColor="{AppThemeBinding Light=White, Dark=#111111}"
                    CornerRadius="0"
                    Padding="12,4"
                    MinimumWidthRequest="80" />

            <BoxView Grid.Column="2"
                     HeightRequest="1"
                     VerticalOptions="Center"
                     BackgroundColor="{AppThemeBinding Light=#DDDDDD, Dark=#333333}" />

            <Button Grid.Column="3"
                    Text="{Binding SettingsToggleText}"
                    FontSize="10"
                    CharacterSpacing="1"
                    Command="{Binding ToggleSettingsCommand}"
                    BackgroundColor="Transparent"
                    TextColor="{AppThemeBinding Light=#888888, Dark=#666666}"
                    Padding="8,4" />
        </Grid>

        <!-- ── Settings + export ──────────────────────────────────────────── -->
        <ScrollView Grid.Row="3"
                    IsVisible="{Binding ShowSettings}">
            <VerticalStackLayout Padding="20,8,20,40" Spacing="0">

                <!-- Seconds per frame -->
                <Label Text="SPEED"
                       FontSize="9"
                       FontAttributes="Bold"
                       CharacterSpacing="2"
                       TextColor="{AppThemeBinding Light=#888888, Dark=#666666}"
                       Margin="0,12,0,4" />

                <Grid ColumnDefinitions="*,Auto">
                    <Slider Grid.Column="0"
                            Minimum="0.1" Maximum="5.0"
                            Value="{Binding SecondsPerFrame}"
                            ThumbColor="{AppThemeBinding Light=Black, Dark=White}"
                            MinimumTrackColor="{AppThemeBinding Light=Black, Dark=White}"
                            MaximumTrackColor="{AppThemeBinding Light=#DDDDDD, Dark=#333333}" />

                    <Label Grid.Column="1"
                           Text="{Binding SecondsPerFrame, StringFormat='{0:F1}s'}"
                           FontSize="11"
                           FontAttributes="Bold"
                           VerticalOptions="Center"
                           TextColor="{AppThemeBinding Light=Black, Dark=White}"
                           MinimumWidthRequest="36"
                           HorizontalTextAlignment="End" />
                </Grid>

                <!-- Transition -->
                <Label Text="TRANSITION"
                       FontSize="9"
                       FontAttributes="Bold"
                       CharacterSpacing="2"
                       TextColor="{AppThemeBinding Light=#888888, Dark=#666666}"
                       Margin="0,12,0,4" />

                <Picker ItemsSource="{Binding TransitionNames}"
                        SelectedIndex="{Binding TransitionIndex}"
                        TextColor="{AppThemeBinding Light=Black, Dark=White}"
                        BackgroundColor="{AppThemeBinding Light=#F2F2F2, Dark=#1E1E1E}"
                        FontSize="11" />

                <!-- Separator before export -->
                <BoxView HeightRequest="1"
                         BackgroundColor="{AppThemeBinding Light=#EEEEEE, Dark=#222222}"
                         Margin="0,20,0,20" />

                <!-- Export -->
                <Grid IsVisible="{Binding IsNotExporting}">
                    <Button Text="EXPORT MP4"
                            FontSize="11"
                            FontAttributes="Bold"
                            CharacterSpacing="2"
                            Clicked="OnExportClicked"
                            BackgroundColor="{AppThemeBinding Light=Black, Dark=White}"
                            TextColor="{AppThemeBinding Light=White, Dark=#111111}"
                            CornerRadius="0" />
                </Grid>

                <VerticalStackLayout IsVisible="{Binding IsExporting}" Spacing="8">
                    <Label Text="EXPORTING…"
                           FontSize="9"
                           FontAttributes="Bold"
                           CharacterSpacing="2"
                           HorizontalOptions="Center"
                           TextColor="{AppThemeBinding Light=#888888, Dark=#666666}" />

                    <ProgressBar Progress="{Binding ExportProgress}"
                                 ProgressColor="{AppThemeBinding Light=Black, Dark=White}" />
                </VerticalStackLayout>

            </VerticalStackLayout>
        </ScrollView>

    </Grid>

</ContentPage>
