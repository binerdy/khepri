<?xml version="1.0" encoding="UTF-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Khepri.SplashPage"
             BackgroundColor="Black"
             Shell.NavBarIsVisible="False">

    <Grid>
        <VerticalStackLayout VerticalOptions="Center"
                             HorizontalOptions="Center"
                             Spacing="18">

            <!-- Top rule — expands from centre -->
            <BoxView x:Name="TopLine"
                     HeightRequest="1"
                     WidthRequest="56"
                     Color="White"
                     HorizontalOptions="Center"
                     Scale="0" />

            <!-- Wordmark -->
            <Label x:Name="KhepriLabel"
                   Text="KHEPRI"
                   FontSize="26"
                   FontAttributes="Bold"
                   CharacterSpacing="9"
                   TextColor="White"
                   HorizontalOptions="Center"
                   Opacity="0"
                   Scale="0.88" />

            <!-- Bottom rule -->
            <BoxView x:Name="BottomLine"
                     HeightRequest="1"
                     WidthRequest="56"
                     Color="White"
                     HorizontalOptions="Center"
                     Scale="0" />

        </VerticalStackLayout>
    </Grid>

</ContentPage>
