<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Inherit from MaterialComponents so CommunityToolkit.Maui.Camera
         (and any other Material widgets) can resolve TextAppearance attributes. -->
    <style name="Maui.MainTheme" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/colorPrimary</item>
        <item name="colorPrimaryDark">@color/colorPrimaryDark</item>
        <item name="colorAccent">@color/colorAccent</item>
    </style>

    <!-- Show the app icon in the native Android 12+ splash screen circle window. -->
    <style name="MyTheme.Splash" parent="Maui.MainTheme">
        <item name="windowNoTitle">true</item>
        <item name="windowActionBar">false</item>
        <item name="android:windowSplashScreenBackground">#0A0A0A</item>
        <item name="android:windowSplashScreenAnimatedIcon">@mipmap/appicon</item>
        <item name="android:windowSplashScreenAnimationDuration">0</item>
    </style>
</resources>
