<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Khepri.MainPage"
             Title="Projects">

    <Grid RowDefinitions="Auto,*,Auto" Padding="16,8">

        <ActivityIndicator Grid.Row="0"
                           IsRunning="{Binding IsBusy}"
                           IsVisible="{Binding IsBusy}"
                           Margin="0,4" />

        <CollectionView Grid.Row="1"
                        x:Name="ProjectsList"
                        ItemsSource="{Binding Projects}"
                        SelectionMode="Single"
                        SelectionChanged="OnProjectSelected">
            <CollectionView.EmptyView>
                <Label Text="No projects yet. Tap + New Project to create one."
                       HorizontalOptions="Center"
                       VerticalOptions="Center"
                       Margin="32"
                       TextColor="{AppThemeBinding Light={StaticResource Gray500}, Dark={StaticResource Gray400}}" />
            </CollectionView.EmptyView>
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Grid Padding="4,12" ColumnDefinitions="*,Auto">
                        <Label Grid.Column="0"
                               Text="{Binding Name}"
                               FontSize="16"
                               VerticalOptions="Center" />
                        <Label Grid.Column="1"
                               Text="{Binding Frames.Count, StringFormat='{0} frames'}"
                               FontSize="13"
                               TextColor="{AppThemeBinding Light={StaticResource Gray500}, Dark={StaticResource Gray400}}"
                               VerticalOptions="Center" />
                    </Grid>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <Button Grid.Row="2"
                Text="+ New Project"
                Clicked="OnNewProjectClicked"
                Margin="0,8,0,0" />

    </Grid>

</ContentPage>
