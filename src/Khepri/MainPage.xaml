<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:Khepri"
             xmlns:appvm="clr-namespace:Khepri.Application.Timelapse;assembly=Khepri.Application"
             x:Class="Khepri.MainPage"
             x:DataType="appvm:ProjectListViewModel"
             Shell.NavBarIsVisible="False"
             BackgroundColor="{AppThemeBinding Light=White, Dark=#111111}">

    <Grid RowDefinitions="Auto,Auto,*,Auto">

        <!-- ── Header ─────────────────────────────────────────────────────── -->
        <Grid Grid.Row="0" Padding="20,52,20,12">

            <!-- Single header — icons disabled until selection mode -->
            <Grid ColumnDefinitions="*,Auto,Auto,Auto,Auto,Auto,Auto">

                <!-- KHEPRI label / selected count -->
                <VerticalStackLayout Grid.Column="0"
                                     VerticalOptions="Center"
                                     Spacing="1"
                                     IsVisible="{Binding IsNotSelecting}">
                    <Label Text="KHEPRI"
                           FontSize="11"
                           FontAttributes="Bold"
                           CharacterSpacing="5"
                           TextColor="{AppThemeBinding Light=Black, Dark=White}" />
                </VerticalStackLayout>

                <Label Grid.Column="0"
                       Text="{Binding SelectedCount, StringFormat='{0} SELECTED'}"
                       FontSize="11"
                       FontAttributes="Bold"
                       CharacterSpacing="2"
                       VerticalOptions="Center"
                       IsVisible="{Binding IsSelecting}"
                       TextColor="{AppThemeBinding Light=Black, Dark=White}" />

                <ActivityIndicator Grid.Column="0"
                                   IsRunning="{Binding IsBusy}"
                                   IsVisible="{Binding IsBusy}"
                                   HorizontalOptions="End"
                                   VerticalOptions="Center"
                                   Color="{AppThemeBinding Light=Black, Dark=White}"
                                   WidthRequest="16"
                                   HeightRequest="16"
                                   Margin="0,0,12,0" />

                <!-- Bin icon — hidden in selection mode -->
                <ImageButton Grid.Column="1"
                             WidthRequest="44"
                             HeightRequest="44"
                             Padding="12"
                             BackgroundColor="Transparent"
                             IsVisible="{Binding IsNotSelecting}"
                             Source="{AppThemeBinding Light=bin_dark.svg, Dark=bin_light.svg}"
                             Clicked="OnDeleteSelectedClicked" />

                <!-- Clone icon — hidden in selection mode -->
                <ImageButton Grid.Column="2"
                             WidthRequest="44"
                             HeightRequest="44"
                             Padding="12"
                             BackgroundColor="Transparent"
                             IsVisible="{Binding IsNotSelecting}"
                             Source="{AppThemeBinding Light=clone_dark.svg, Dark=clone_light.svg}"
                             Clicked="OnCloneSelectedClicked" />

                <!-- Import icon — hidden in selection mode -->
                <Button Grid.Column="3"
                        Text="IMPORT"
                        FontSize="11"
                        CharacterSpacing="1"
                        Padding="12"
                        BackgroundColor="Transparent"
                        TextColor="{AppThemeBinding Light=#888888, Dark=#666666}"
                        IsVisible="{Binding IsNotSelecting}"
                        Clicked="OnImportClicked" />

                <!-- Export icon — hidden in selection mode -->
                <Button Grid.Column="4"
                        Text="EXPORT"
                        FontSize="11"
                        CharacterSpacing="1"
                        Padding="12"
                        BackgroundColor="Transparent"
                        TextColor="{AppThemeBinding Light=#888888, Dark=#666666}"
                        IsVisible="{Binding IsNotSelecting}"
                        Clicked="OnExportClicked" />

                <!-- Cancel — visible only in selection mode -->
                <Button Grid.Column="5"
                        Text="CANCEL"
                        FontSize="11"
                        CharacterSpacing="1"
                        Clicked="OnExitSelectModeClicked"
                        BackgroundColor="Transparent"
                        TextColor="{AppThemeBinding Light=#888888, Dark=#666666}"
                        IsVisible="{Binding IsSelecting}"
                        Padding="8,0" />

                <!-- OK — visible in selection mode to confirm action -->
                <Button Grid.Column="6"
                        Text="OK"
                        FontSize="11"
                        FontAttributes="Bold"
                        CharacterSpacing="1"
                        Clicked="OnConfirmClicked"
                        BackgroundColor="Transparent"
                        TextColor="{AppThemeBinding Light=Black, Dark=White}"
                        IsVisible="{Binding IsSelecting}"
                        Padding="8,0"
                        MinimumWidthRequest="40" />

                <!-- + button — visible only when not selecting -->
                <Button Grid.Column="6"
                        Text="+"
                        FontSize="24"
                        Clicked="OnNewProjectClicked"
                        BackgroundColor="Transparent"
                        TextColor="{AppThemeBinding Light=Black, Dark=White}"
                        IsVisible="{Binding IsNotSelecting}"
                        Padding="8,0"
                        MinimumWidthRequest="40" />
            </Grid>

        </Grid>

        <!-- ── Search ─────────────────────────────────────────────────────── -->
        <Border Grid.Row="1"
                Margin="20,0,20,16"
                BackgroundColor="{AppThemeBinding Light=#F2F2F2, Dark=#1E1E1E}"
                StrokeThickness="0"
                StrokeShape="Rectangle">
            <SearchBar Text="{Binding SearchText}"
                       Placeholder="SEARCH PROJECTS"
                       PlaceholderColor="{AppThemeBinding Light=#AAAAAA, Dark=#555555}"
                       TextColor="{AppThemeBinding Light=Black, Dark=White}"
                       BackgroundColor="Transparent"
                       FontSize="11"
                       CharacterSpacing="1"
                       CancelButtonColor="{AppThemeBinding Light=#888888, Dark=#666666}" />
        </Border>

        <!-- ── Project grid ───────────────────────────────────────────────── -->
        <CollectionView Grid.Row="2"
                        x:Name="ProjectsList"
                        ItemsSource="{Binding FilteredProjects}"
                        SelectionMode="None"
                        Margin="20,0,20,0">
            <CollectionView.ItemsLayout>
                <GridItemsLayout Orientation="Vertical"
                                 Span="2"
                                 VerticalItemSpacing="20"
                                 HorizontalItemSpacing="12" />
            </CollectionView.ItemsLayout>

            <CollectionView.EmptyView>
                <VerticalStackLayout HorizontalOptions="Center"
                                     VerticalOptions="Center"
                                     Spacing="6"
                                     Margin="32,48">
                    <Label Text="NO PROJECTS"
                           FontSize="11"
                           FontAttributes="Bold"
                           CharacterSpacing="3"
                           HorizontalOptions="Center"
                           TextColor="{AppThemeBinding Light=#BBBBBB, Dark=#444444}" />
                    <Label Text="Tap + to create your first timelapse."
                           FontSize="12"
                           HorizontalOptions="Center"
                           TextColor="{AppThemeBinding Light=#BBBBBB, Dark=#444444}" />
                </VerticalStackLayout>
            </CollectionView.EmptyView>

            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="appvm:ProjectDisplayItem">
                    <Grid RowDefinitions="Auto,Auto,Auto,Auto"
                          Padding="0,0,0,4">

                        <Grid.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnItemTapped" />
                        </Grid.GestureRecognizers>

                        <!-- Thumbnail placeholder (always visible; replaced by image) -->
                        <BoxView Grid.Row="0"
                                 HeightRequest="160"
                                 BackgroundColor="{AppThemeBinding Light=#F2F2F2, Dark=#1E1E1E}" />

                        <!-- Latest frame image (overlaid; transparent aspect crop) -->
                        <Image Grid.Row="0"
                               Source="{Binding Project.LatestFrame.FilePath}"
                               Aspect="AspectFill"
                               HeightRequest="160" />

                        <!-- Selection overlay — semi-transparent tint over thumbnail -->
                        <BoxView Grid.Row="0"
                                 BackgroundColor="#99000000"
                                 IsVisible="{Binding IsSelected}" />

                        <!-- Checkmark indicator -->
                        <Label Grid.Row="0"
                               Text="✓"
                               FontSize="16"
                               FontAttributes="Bold"
                               TextColor="White"
                               HorizontalOptions="End"
                               VerticalOptions="Start"
                               Margin="0,10,10,0"
                               IsVisible="{Binding IsSelected}" />

                        <!-- Thin separator line — grid accent -->
                        <BoxView Grid.Row="1"
                                 HeightRequest="1"
                                 BackgroundColor="{AppThemeBinding Light=Black, Dark=White}" />

                        <!-- Project name -->
                        <Label Grid.Row="2"
                               Text="{Binding Project.Name}"
                               FontSize="13"
                               FontAttributes="Bold"
                               LineBreakMode="TailTruncation"
                               TextColor="{AppThemeBinding Light=Black, Dark=White}"
                               Margin="0,6,0,0" />

                        <!-- Last capture date -->
                        <Label Grid.Row="3"
                               Text="{Binding Project.LatestFrame.CapturedAt, StringFormat='{0:d MMM yyyy}'}"
                               FontSize="10"
                               CharacterSpacing="0.5"
                               TextColor="{AppThemeBinding Light=#888888, Dark=#666666}"
                               Margin="0,2,0,0" />
                    </Grid>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <!-- ── Bottom safe-area spacer ────────────────────────────────────── -->
        <BoxView Grid.Row="3"
                 HeightRequest="16"
                 BackgroundColor="Transparent" />

    </Grid>

</ContentPage>

